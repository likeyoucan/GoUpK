{
  "name": "my-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:watch:css\" \"serve www\"",
    "start": "serve www",
    
    "// --- ИСПРАВЛЕННЫЕ СКРИПТЫ ДЛЯ TAILWIND v4 --- //": "",
    "build:css": "tailwindcss -i ./input.css -o ./www/styles.css --minify --content \"./www/**/*.html,./www/js/**/*.js\"",
    "watch:css": "tailwindcss -i ./input.css -o ./www/styles.css --watch --content \"./www/**/*.html,./www/js/**/*.js\"",
    
    "// --- CAPACITOR И СБОРКА APK --- //": "",
    "build": "npm run build:css && npx cap sync android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capawesome-team/capacitor-android-foreground-service": "^8.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "concurrently": "^8.2.2",
    "serve": "^14.2.3",
    "tailwindcss": "^4.0.0"
  }
}